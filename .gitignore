# Local data and OS/editor noise
.DS_Store
Thumbs.db
.vscode/
__pycache__/
*.pyc

# Real user data backups must stay local unless explicitly sanitized.
*.local.json
*.backup.json
*.pnhbackup
exports/
encrypted_exports/

# Future local companion private storage/runtime artifacts.
*.vault
*.sqlite
*.sqlite3
*.db
companion/private/
companion/runtime/
companion/logs/

# Browser QA generated artifacts can contain screenshots or traces.
ops/runs/*/artifacts/
ops/runs/**/artifacts/
test-results/

# Secrets are not used by this project.
.env
.env.*
*secret*
*token*
*credential*
*.pem
*.key

# Secret-handling source code is tracked; secret values/artifacts remain ignored.
!companion/secret_backends.py
!scripts/vault_secret_store.py
!scripts/vault_secret_status.py
!scripts/vault_secret_delete.py
!scripts/vault_secret_smoke_check.py
